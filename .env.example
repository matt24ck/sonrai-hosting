# Copy to ".env" for local dev. In production (Railway), set these in the service Variables tab.
# Never commit a real key.

# --- Per-store keys (recommended) ---
# One key per store gives you per-store usage monitoring in the Anthropic console.
# Convention: ANTHROPIC_API_KEY_<STOREID uppercased>. Example for store id "enrgy":
ANTHROPIC_API_KEY_ENRGY=

# --- Fallback key (optional) ---
# Used for any store that doesn't have its own key set above. Handy for local dev.
ANTHROPIC_API_KEY=

# Optional: override the port (Railway sets PORT automatically).
# PORT=3000

# --- Catalogue auto-refresh ---
# How often the server re-fetches each store's products.json (minutes). 0 disables. Default 180.
# CATALOGUE_REFRESH_MINUTES=180
# Optional shared secret to enable POST /api/refresh (manual / Shopify-webhook trigger).
# Leave unset to disable that endpoint.
# REFRESH_TOKEN=
